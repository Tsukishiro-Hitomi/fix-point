# Copy to .env and fill in. .env is gitignored — never commit real values.
# Security: never paste a real key into an issue / PR / screenshot / demo GIF.

# Gateway credentials (read automatically by anthropic.Anthropic())
ANTHROPIC_API_KEY=sk-REPLACE_ME
ANTHROPIC_BASE_URL=https://your-gateway.example/v1

# Model + run knobs (non-secret; safe defaults live in agent/config.py)
# Mapped into Config by Config.from_env():
#   FIXPOINT_MODEL      -> config.model
#   MAX_STEPS           -> config.max_steps
#   RUN_TESTS_TIMEOUT   -> config.run_tests_timeout_s
# (all other knobs use the defaults in agent/config.py)
FIXPOINT_MODEL=anthropic/claude-opus-4.8
MAX_STEPS=30
RUN_TESTS_TIMEOUT=60
